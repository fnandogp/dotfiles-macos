{
  "globalShortcut": "",
  "mcpServers": {
    "shopify-dev-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@shopify/dev-mcp@latest"
      ]
    },
    "productive": {
      "command": "npx",
