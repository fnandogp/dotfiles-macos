{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "opencode-openai-codex-auth",
    "@franlol/opencode-md-table-formatter",
    // "oh-my-opencode@latest"
  ],
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--open-web-dashboard",
        "False"
      ],
      "enabled": true,
      "environment": {}
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "environment": {}
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "environment": {}
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "buxfer": {
      "type": "remote",
      "url": "https://buxfer-mcp.fnandogp.workers.dev/mcp",
      "enabled": true,
      "headers": {
        "x-buxfer-email": "{env:BUXFER_EMAIL}",
        "x-buxfer-password": "{env:BUXFER_PASSWORD}"
      }
    },
    "pocketsmith": {
      "type": "remote",
      "url": "https://pocketsmith-mcp.fnandogp.workers.dev/mcp",
      "enabled": true,
      "headers": {
        "X-POCKETSMITH-API-KEY": "{env:POCKETSMITH_API_KEY}"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time"
      ],
      "enabled": true
    }
  }
}
